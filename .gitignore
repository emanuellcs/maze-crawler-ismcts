# C/C++ dependency sidecars produced by native compiler invocations.
*.d

# Object files from local CMake builds or ad hoc Kaggle JIT experiments.
*.slo
*.lo
*.o
*.obj

# Precompiled header artifacts are machine-local and not part of the source bundle.
*.gch
*.pch

# Platform linker/debug databases generated beside compiled extensions.
*.ilk

*.pdb

# Native extension outputs, including `crawler_engine*.so`, are rebuildable.
*.so
*.dylib
*.dll
*.so.*


# Fortran module patterns are inherited from a broad native-template ignore set.
*.mod
*.smod

# Static archives are not used by the pybind build and should stay out of git.
*.lai
*.la
*.a
*.lib

# Local binary executables are build artifacts, not submission inputs.
*.exe
*.out
*.app

# CMake and compiler output directories.
build/
Build/
build-*/

# CMake generated files that can be recreated from CMakeLists.txt.
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json

# Editor, compiler, and diagnostic temporary files.
*.tmp
*.log
*.bak
*.swp

# Optional vcpkg dependency cache, if used locally.
vcpkg_installed/

# Split debug information files.
*.dwo

# Test output and Python cache directories.
Testing/
.cache/

# Codespace/devcontainer metadata is environment-specific.
.devcontainer/

# Pytest and Python bytecode caches.
.pytest_cache/
__pycache__/

# Kaggle source bundle generated by `package_submission.py`.
submission.tar.gz
